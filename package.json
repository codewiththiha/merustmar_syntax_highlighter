{
  "name": "merustmar",
  "displayName": "Merustmar",
  "publisher": "codewiththiha",
  "icon": "icon.png",
  "description": "Merustmar programming language syntax highlighting",
  "version": "0.0.1",
  "repository" : "https://github.com/codewiththiha/merustmar_syntax_highlighter.git",
  "engines": {
    "vscode": "^1.115.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [{
      "id": "mrm",
      "aliases": ["Merustmar", "mrm"],
      "extensions": [".mrm"],
      "configuration": "./language-configuration.json"
    }],
    "grammars": [{
      "language": "mrm",
      "scopeName": "source.mrm",
      "path": "./syntaxes/mrm.tmLanguage.json"
    }]
  }
}
